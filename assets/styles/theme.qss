/* ============================================================
   DishBoard — Black & Orange theme, applied over qt-material dark_amber
   ============================================================ */

* {
    font-family: "SF Pro Display", "SF Pro Text", -apple-system,
                 ".AppleSystemUIFont", "Helvetica Neue", Arial, sans-serif;
}

QMainWindow, QWidget {
    background-color: #090909;
    color: #d4d4d4;
}

/* ---- Sidebar ---- */
QWidget#sidebar {
    background-color: #050505;
    border-right: 1px solid #181818;
}

QLabel#app-logo-label {
    background-color: transparent;
    color: #ffffff;
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
}

QWidget#sidebar-divider {
    background-color: #1a1a1a;
    max-height: 1px;
    min-height: 1px;
}

QWidget#sidebar-accent {
    background-color: #ff6b35;
    max-height: 2px;
    min-height: 2px;
    border-radius: 1px;
}

QLabel#sidebar-section-label {
    background-color: transparent;
    color: #4a4a4a;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    padding: 0 18px;
}

QLabel#sidebar-date-lbl {
    background-color: transparent;
    color: #5a5a5a;
    font-size: 12px;
    padding: 0 18px;
}

QLabel#sidebar-version-lbl {
    background-color: transparent;
    color: #3a3a3a;
    font-size: 11px;
    padding: 0 18px;
}

/* ---- Nav buttons ---- */
QPushButton#nav-btn {
    background-color: transparent;
    color: #505050;
    border: none;
    border-radius: 9px;
    padding: 0 14px;
    text-align: left;
    font-size: 14px;
    font-weight: 500;
    margin: 0px 8px;
}

QPushButton#nav-btn:hover {
    background-color: #141414;
    color: #c0c0c0;
}

/* :checked colour handled inline per-button in NavButton for per-section colors */
QPushButton#nav-btn:checked {
    font-weight: 600;
}

QPushButton#toggle-btn {
    background-color: transparent;
    border: none;
    border-radius: 7px;
    padding: 2px;
}
QPushButton#toggle-btn:hover { background-color: #131313; }

/* ---- Content area ---- */
QStackedWidget#content-area { background-color: #090909; }

/* ---- Cards ---- */
QWidget#card {
    background-color: #111111;
    border-radius: 12px;
    border: 1px solid #1c1c1c;
}

QWidget#stat-card {
    background-color: #111111;
    border-radius: 12px;
    border: 1px solid #1c1c1c;
}

QWidget#plan-card {
    background-color: #111111;
    border-radius: 12px;
    border: 1px solid #1c1c1c;
}

QWidget#claude-card {
    background-color: #0f0f0f;
    border-radius: 12px;
    border: 1px solid rgba(255, 107, 53, 0.25);
}

QWidget#accent-card {
    background-color: rgba(255, 107, 53, 0.06);
    border-radius: 12px;
    border: 1px solid rgba(255, 107, 53, 0.2);
}

QWidget#meal-slot {
    background-color: #0e0e0e;
    border-radius: 10px;
    border: 1px solid #2a2a2a;
}
QWidget#meal-slot:hover {
    border-color: rgba(255, 107, 53, 0.5);
    background-color: rgba(255, 107, 53, 0.05);
}

/* ---- Content divider (inline widget dividers) ---- */
QWidget#content-divider {
    background-color: #2a2a2a;
}

/* ---- Typography ---- */
QLabel#page-title {
    background-color: transparent;
    color: #f0f0f0;
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.5px;
}

QLabel#page-date {
    background-color: transparent;
    color: #888888;
    font-size: 14px;
}

QLabel#section-label {
    background-color: transparent;
    color: #666666;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.4px;
}

QLabel#stat-value {
    background-color: transparent;
    color: #f0f0f0;
    font-size: 32px;
    font-weight: 700;
}

QLabel#stat-label {
    background-color: transparent;
    color: #888888;
    font-size: 13px;
    font-weight: 500;
}

QLabel#card-title {
    background-color: transparent;
    color: #c8c8c8;
    font-size: 15px;
    font-weight: 600;
}

QLabel#card-body {
    background-color: transparent;
    color: #909090;
    font-size: 14px;
}

QLabel#tip-text {
    background-color: transparent;
    color: #b0a090;
    font-size: 14px;
}

QLabel#meal-slot-label {
    background-color: transparent;
    color: #505050;
    font-size: 13px;
}

QLabel#placeholder-text {
    background-color: transparent;
    color: #505050;
    font-size: 16px;
    font-weight: 500;
}

QLabel#placeholder-sub {
    background-color: transparent;
    color: #404040;
    font-size: 14px;
}

QLabel#claude-feature-lbl {
    background-color: transparent;
    color: #888888;
    font-size: 14px;
}

QLabel#claude-notice {
    background-color: transparent;
    color: #888888;
    font-size: 12px;
}

/* ---- Primary button ---- */
QPushButton#primary-btn {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #ff7540, stop:1 #e85d25);
    color: #fff0ea;
    border: 1px solid rgba(255, 107, 53, 0.35);
    border-radius: 10px;
    padding: 0 22px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.4px;
    min-height: 34px;
}
QPushButton#primary-btn:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #ff8855, stop:1 #f06f35);
    border-color: rgba(255, 107, 53, 0.55);
}
QPushButton#primary-btn:pressed {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #d55520, stop:1 #bd4a18);
    border-color: rgba(200, 80, 30, 0.4);
}
QPushButton#primary-btn:disabled {
    background: rgba(60, 30, 15, 0.5);
    color: rgba(255, 150, 100, 0.3);
    border-color: transparent;
}

QPushButton#ghost-btn {
    background-color: #111111;
    color: #666666;
    border: 1px solid #1c1c1c;
    border-radius: 6px;
    padding: 0px 10px;
    font-size: 11px;
    font-weight: 500;
}
QPushButton#ghost-btn:hover {
    background-color: #161616;
    color: #b0b0b0;
    border-color: #282828;
}

QPushButton#quick-action-btn {
    background-color: #0e0e0e;
    color: #808080;
    border: 1px solid #1c1c1c;
    border-radius: 12px;
    padding: 20px 22px;
    font-size: 14px;
    font-weight: 500;
    text-align: left;
}
QPushButton#quick-action-btn:hover {
    background-color: #141414;
    color: #d0d0d0;
    border-color: #282828;
}

/* ---- Inputs ---- */
QLineEdit {
    background-color: #111111;
    color: #e8e8e8;
    border: 1px solid #1c1c1c;
    border-radius: 9px;
    padding: 10px 16px;
    font-size: 14px;
    min-height: 20px;
    selection-background-color: rgba(255, 107, 53, 0.35);
    selection-color: #ffffff;
}
QLineEdit:enabled { color: #e8e8e8; }
QLineEdit:focus { border-color: rgba(255, 107, 53, 0.5); background-color: #131313; color: #e8e8e8; }
QLineEdit::placeholder { color: #555555; }
QLineEdit:disabled { color: #3a3a3a; background-color: #0d0d0d; border-color: #161616; }

/* ---- Combo boxes ---- */
QComboBox {
    background-color: #111111;
    color: #e8e8e8;
    border: 1px solid #1c1c1c;
    border-radius: 9px;
    padding: 10px 14px;
    font-size: 14px;
    min-height: 20px;
}
QComboBox:focus { border-color: rgba(255, 107, 53, 0.5); }
QComboBox::drop-down { border: none; width: 22px; }
QComboBox QAbstractItemView {
    background-color: #111111;
    color: #e8e8e8;
    border: 1px solid #1c1c1c;
    selection-background-color: rgba(255, 107, 53, 0.2);
    selection-color: #ffffff;
    font-size: 14px;
    padding: 4px;
}
QComboBox QAbstractItemView::item { min-height: 28px; padding: 4px 10px; }

/* ---- Checkbox ---- */
QCheckBox {
    background-color: transparent;
    color: #a8a8a8;
    font-size: 14px;
    spacing: 10px;
    outline: 0px;
}
QCheckBox::indicator {
    width: 19px;
    height: 19px;
    border-radius: 5px;
    border: 1.5px solid #282828;
    background-color: #0a0a0a;
    image: none;
}
QCheckBox::indicator:unchecked         { background-color: #0a0a0a; border-color: #282828; image: none; }
QCheckBox::indicator:unchecked:hover   { background-color: #0a0a0a; border-color: #ff6b35; image: none; }
QCheckBox::indicator:checked           { background-color: #ff6b35; border-color: #ff6b35; image: none; }
QCheckBox::indicator:checked:hover     { background-color: #ff7d4d; border-color: #ff7d4d; image: none; }

/* ---- Shopping items ---- */
QWidget#shopping-item {
    background-color: #0e0e0e;
    border-radius: 10px;
    border: 1px solid #191919;
    min-height: 56px;
}

QPushButton#delete-btn {
    background-color: transparent;
    border: none;
    border-radius: 6px;
    padding: 2px;
}
QPushButton#delete-btn:hover { background-color: rgba(255, 107, 53, 0.1); }

/* ---- Progress bars ---- */
QProgressBar {
    background-color: #141414;
    border-radius: 4px;
    border: none;
}
QProgressBar::chunk { border-radius: 4px; background-color: #ff6b35; }

/* ---- Scrollbars ---- */
QScrollBar:vertical { background: transparent; width: 5px; margin: 0; }
QScrollBar::handle:vertical { background: #1e1e1e; border-radius: 2px; min-height: 24px; }
QScrollBar::handle:vertical:hover { background: #2e2e2e; }
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0; }

QScrollBar:horizontal { background: transparent; height: 5px; }
QScrollBar::handle:horizontal { background: #1e1e1e; border-radius: 2px; min-width: 24px; }
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal { width: 0; }

/* ---- Status bar ---- */
QStatusBar {
    background-color: #050505;
    color: #282828;
    border-top: 1px solid #141414;
    font-size: 11px;
    padding: 2px 10px;
}
QStatusBar::item { border: none; }

/* ---- Scroll area ---- */
QScrollArea { border: none; background-color: transparent; }
QScrollArea > QWidget > QWidget { background-color: transparent; }
