/* ============================================================
   DishBoard — Black & Orange theme, applied over qt-material dark_amber
   ============================================================ */

* {
    font-family: "Segoe UI", "SF Pro Text", -apple-system,
                 ".AppleSystemUIFont", "Helvetica Neue", Arial, sans-serif;
}

QMainWindow, QWidget {
    background-color: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #0c121a, stop:0.45 #0f1621, stop:1 #0b1118
    );
    color: #dde3ec;
}

/* ---- Sidebar ---- */
QWidget#sidebar {
    background-color: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #0b1017, stop:1 #090d13
    );
    border-right: 1px solid #1d2430;
}

QLabel#app-logo-label {
    background-color: transparent;
    color: #ffffff;
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
}

QWidget#sidebar-divider {
    background-color: #202734;
    max-height: 1px;
    min-height: 1px;
}

QWidget#sidebar-accent {
    background-color: #ff6b35;
    max-height: 2px;
    min-height: 2px;
    border-radius: 1px;
}

QLabel#sidebar-section-label {
    background-color: transparent;
    color: #4a4a4a;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    padding: 0 18px;
}

QLabel#sidebar-date-lbl {
    background-color: transparent;
    color: #7f8a9a;
    font-size: 12px;
    padding: 0 18px;
}

QLabel#sidebar-version-lbl {
    background-color: transparent;
    color: #6e7785;
    font-size: 11px;
    padding: 0 18px;
}

/* ---- Nav buttons ---- */
QPushButton#nav-btn {
    background-color: transparent;
    color: #8d96a5;
    border: none;
    border-radius: 10px;
    padding: 0 15px;
    text-align: left;
    font-size: 14px;
    font-weight: 500;
    margin: 0px 8px;
}

QPushButton#nav-btn:hover {
    background-color: qlineargradient(
        x1:0, y1:0, x2:1, y2:0,
        stop:0 rgba(27,37,51,0.95), stop:1 rgba(22,31,43,0.95)
    );
    color: #e7edf7;
}

/* :checked colour handled inline per-button in NavButton for per-section colors */
QPushButton#nav-btn:checked {
    font-weight: 600;
}

QPushButton#toggle-btn {
    background-color: transparent;
    border: none;
    border-radius: 7px;
    padding: 2px;
}
QPushButton#toggle-btn:hover { background-color: #151d28; }

/* ---- Content area ---- */
QStackedWidget#content-area { background-color: #0d1117; }

/* ---- Cards ---- */
QWidget#card {
    background-color: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #18212d, stop:1 #121a24
    );
    border-radius: 14px;
    border: 1px solid #273141;
}

QWidget#stat-card {
    background-color: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #192331, stop:1 #121b26
    );
    border-radius: 14px;
    border: 1px solid #273141;
}

QWidget#plan-card {
    background-color: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #18222f, stop:1 #131c27
    );
    border-radius: 14px;
    border: 1px solid #273141;
}

QWidget#claude-card {
    background-color: #111720;
    border-radius: 14px;
    border: 1px solid rgba(255, 107, 53, 0.28);
}

QWidget#accent-card {
    background-color: rgba(255, 107, 53, 0.08);
    border-radius: 14px;
    border: 1px solid rgba(255, 107, 53, 0.22);
}

QWidget#meal-slot {
    background-color: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #162130, stop:1 #111a26
    );
    border-radius: 10px;
    border: 1px solid #2a3445;
}
QWidget#meal-slot:hover {
    border-color: rgba(255, 107, 53, 0.58);
    background-color: rgba(255, 107, 53, 0.07);
}

/* ---- Content divider (inline widget dividers) ---- */
QWidget#content-divider {
    background-color: #2b3547;
}

/* ---- Typography ---- */
QLabel#page-title {
    background-color: transparent;
    color: #f5f8ff;
    font-size: 30px;
    font-weight: 700;
    letter-spacing: -0.4px;
}

QLabel#page-date {
    background-color: transparent;
    color: #9da7b6;
    font-size: 13px;
}

QLabel#section-label {
    background-color: transparent;
    color: #8892a0;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.4px;
}

QLabel#stat-value {
    background-color: transparent;
    color: #f5f8ff;
    font-size: 30px;
    font-weight: 700;
}

QLabel#stat-label {
    background-color: transparent;
    color: #9da7b6;
    font-size: 12px;
    font-weight: 500;
}

QLabel#card-title {
    background-color: transparent;
    color: #e4e9f1;
    font-size: 16px;
    font-weight: 600;
}

QLabel#card-body {
    background-color: transparent;
    color: #a8b2c0;
    font-size: 13px;
}

QLabel#tip-text {
    background-color: transparent;
    color: #c2b39b;
    font-size: 13px;
}

QLabel#meal-slot-label {
    background-color: transparent;
    color: #8a95a6;
    font-size: 12px;
}

QLabel#placeholder-text {
    background-color: transparent;
    color: #95a1b3;
    font-size: 17px;
    font-weight: 500;
}

QLabel#placeholder-sub {
    background-color: transparent;
    color: #7f8a9a;
    font-size: 13px;
}

QLabel#claude-feature-lbl {
    background-color: transparent;
    color: #9da7b6;
    font-size: 13px;
}

QLabel#claude-notice {
    background-color: transparent;
    color: #9da7b6;
    font-size: 12px;
}

/* ---- Primary button ---- */
QPushButton#primary-btn {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #ff7540, stop:1 #e85d25);
    color: #fff0ea;
    border: 1px solid rgba(255, 107, 53, 0.35);
    border-radius: 10px;
    padding: 0 22px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.4px;
    min-height: 34px;
}
QPushButton#primary-btn:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #ff8855, stop:1 #f06f35);
    border-color: rgba(255, 107, 53, 0.55);
}
QPushButton#primary-btn:pressed {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #d55520, stop:1 #bd4a18);
    border-color: rgba(200, 80, 30, 0.4);
}
QPushButton#primary-btn:disabled {
    background: rgba(60, 30, 15, 0.5);
    color: rgba(255, 150, 100, 0.3);
    border-color: transparent;
}

QPushButton#ghost-btn {
    background-color: #141b25;
    color: #8d96a5;
    border: 1px solid #2a3445;
    border-radius: 8px;
    padding: 0px 12px;
    font-size: 12px;
    font-weight: 600;
}
QPushButton#ghost-btn:hover {
    background-color: #1a2230;
    color: #e5ebf4;
    border-color: #364257;
}

QPushButton#quick-action-btn {
    background-color: #121923;
    color: #9da7b6;
    border: 1px solid #273141;
    border-radius: 14px;
    padding: 16px 20px;
    font-size: 14px;
    font-weight: 500;
    text-align: left;
}
QPushButton#quick-action-btn:hover {
    background-color: #17202d;
    color: #eef3fc;
    border-color: #364257;
}

/* ---- Inputs ---- */
QLineEdit {
    background-color: #111823;
    color: #eef3fc;
    border: 1px solid #2a3445;
    border-radius: 10px;
    padding: 10px 14px;
    font-size: 14px;
    min-height: 20px;
    selection-background-color: rgba(255, 107, 53, 0.35);
    selection-color: #ffffff;
}
QLineEdit:enabled { color: #eef3fc; }
QLineEdit:focus { border-color: rgba(255, 107, 53, 0.58); background-color: #131b27; color: #eef3fc; }
QLineEdit::placeholder { color: #6f7a8b; }
QLineEdit:disabled { color: #5a6473; background-color: #10151d; border-color: #1f2835; }

/* ---- Combo boxes ---- */
QComboBox {
    background-color: #111823;
    color: #eef3fc;
    border: 1px solid #2a3445;
    border-radius: 10px;
    padding: 10px 12px;
    font-size: 14px;
    min-height: 20px;
}
QComboBox:focus { border-color: rgba(255, 107, 53, 0.58); }
QComboBox::drop-down { border: none; width: 22px; }
QComboBox QAbstractItemView {
    background-color: #111823;
    color: #eef3fc;
    border: 1px solid #2a3445;
    selection-background-color: rgba(255, 107, 53, 0.2);
    selection-color: #ffffff;
    font-size: 14px;
    padding: 4px;
}
QComboBox QAbstractItemView::item { min-height: 28px; padding: 4px 10px; }

/* ---- Checkbox ---- */
QCheckBox {
    background-color: transparent;
    color: #c9d2e0;
    font-size: 13px;
    font-weight: 600;
    spacing: 10px;
    outline: 0px;
}
QCheckBox::indicator {
    width: 19px;
    height: 19px;
    border-radius: 5px;
    border: 1.5px solid #354052;
    background-color: #111823;
    image: none;
}
QCheckBox::indicator:unchecked         { background-color: #111823; border-color: #354052; image: none; }
QCheckBox::indicator:unchecked:hover   { background-color: #111823; border-color: #ff6b35; image: none; }
QCheckBox::indicator:checked           { background-color: #ff6b35; border-color: #ff6b35; image: none; }
QCheckBox::indicator:checked:hover     { background-color: #ff7d4d; border-color: #ff7d4d; image: none; }

/* ---- Shopping items ---- */
QWidget#shopping-item {
    background-color: #121923;
    border-radius: 10px;
    border: 1px solid #273141;
    min-height: 56px;
}

QPushButton#delete-btn {
    background-color: transparent;
    border: none;
    border-radius: 6px;
    padding: 2px;
}
QPushButton#delete-btn:hover { background-color: rgba(255, 107, 53, 0.1); }

/* ---- Progress bars ---- */
QProgressBar {
    background-color: #1b2432;
    border-radius: 4px;
    border: none;
}
QProgressBar::chunk { border-radius: 4px; background-color: #ff6b35; }

/* ---- Scrollbars ---- */
QScrollBar:vertical { background: transparent; width: 5px; margin: 0; }
QScrollBar::handle:vertical { background: #2f3a4b; border-radius: 2px; min-height: 24px; }
QScrollBar::handle:vertical:hover { background: #445268; }
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0; }

QScrollBar:horizontal { background: transparent; height: 5px; }
QScrollBar::handle:horizontal { background: #2f3a4b; border-radius: 2px; min-width: 24px; }
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal { width: 0; }

/* ---- Status bar ---- */
QStatusBar {
    background-color: #0a0e14;
    color: #7f8a9a;
    border-top: 1px solid #1d2430;
    font-size: 11px;
    padding: 2px 10px;
}
QStatusBar::item { border: none; }

/* ---- Scroll area ---- */
QScrollArea { border: none; background-color: transparent; }
QScrollArea > QWidget > QWidget { background-color: transparent; }

/* ---- Dialogs ---- */
QDialog {
    background-color: #101722;
    color: #dde3ec;
}
QDialogButtonBox QPushButton {
    background-color: #141b25;
    color: #8d96a5;
    border: 1px solid #2a3445;
    border-radius: 8px;
    padding: 8px 18px;
    font-size: 13px;
    font-weight: 600;
}
QDialogButtonBox QPushButton:hover {
    background-color: #1a2230;
    color: #e5ebf4;
    border-color: #364257;
}
QDialogButtonBox QPushButton[text="OK"],
QDialogButtonBox QPushButton[text="Save"] {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #ff7540, stop:1 #e85d25);
    color: #fff0ea;
    border: 1px solid rgba(255, 107, 53, 0.35);
}
QDialogButtonBox QPushButton[text="OK"]:hover,
QDialogButtonBox QPushButton[text="Save"]:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #ff8855, stop:1 #f06f35);
    border-color: rgba(255, 107, 53, 0.55);
}

/* ---- Message boxes ---- */
QMessageBox {
    background-color: #101722;
    color: #dde3ec;
}
QMessageBox QPushButton {
    background-color: #141b25;
    color: #8d96a5;
    border: 1px solid #2a3445;
    border-radius: 8px;
    padding: 8px 18px;
    min-width: 70px;
    font-size: 13px;
    font-weight: 600;
}
QMessageBox QPushButton:hover {
    background-color: #1a2230;
    color: #e5ebf4;
    border-color: #364257;
}

/* ---- Tooltips ---- */
QToolTip {
    background-color: #111823;
    color: #eef3fc;
    border: 1px solid #2a3445;
    border-radius: 5px;
    padding: 4px 8px;
    font-size: 12px;
}
