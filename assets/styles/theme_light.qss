/* ============================================================
   DishBoard — Light mode theme
   Comfortable off-white palette, same orange accent #ff6b35
   ============================================================ */

* {
    font-family: "Segoe UI", "SF Pro Text", -apple-system,
                 ".AppleSystemUIFont", "Helvetica Neue", Arial, sans-serif;
}

QMainWindow, QWidget {
    background-color: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #faf7f2, stop:0.5 #f4efe8, stop:1 #efe8de
    );
    color: #1d1c19;
}

/* ---- Sidebar ---- */
QWidget#sidebar {
    background-color: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #f5efe7, stop:1 #ede5db
    );
    border-right: 1px solid #ddd4c8;
}

QLabel#app-logo-label {
    background-color: transparent;
    color: #111111;
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
}

QWidget#sidebar-divider {
    background-color: #d8cdc1;
    max-height: 1px;
    min-height: 1px;
}

QWidget#sidebar-accent {
    background-color: #ff6b35;
    max-height: 2px;
    min-height: 2px;
    border-radius: 1px;
}

QLabel#sidebar-section-label {
    background-color: transparent;
    color: #888888;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    padding: 0 18px;
}

QLabel#sidebar-date-lbl {
    background-color: transparent;
    color: #756e64;
    font-size: 12px;
    padding: 0 18px;
}

QLabel#sidebar-version-lbl {
    background-color: transparent;
    color: #8a8176;
    font-size: 11px;
    padding: 0 18px;
}

/* ---- Nav buttons ---- */
QPushButton#nav-btn {
    background-color: transparent;
    color: #665f58;
    border: none;
    border-radius: 10px;
    padding: 0 15px;
    text-align: left;
    font-size: 14px;
    font-weight: 500;
    margin: 1px 8px;
}

QPushButton#nav-btn:hover {
    background-color: rgba(0,0,0,0.03);
    color: #211d18;
}

QPushButton#nav-btn:checked {
    background-color: rgba(255, 107, 53, 0.08);
    color: #d75a27;
    font-weight: 600;
    border-left: 2px solid #ff6b35;
    padding-left: 12px;
}

QPushButton#toggle-btn {
    background-color: transparent;
    border: none;
    border-radius: 7px;
    padding: 2px;
}
QPushButton#toggle-btn:hover { background-color: #efe5d9; }

/* ---- Back bar ---- */
QWidget#back-bar {
    background-color: #f2ebe3;
    border-bottom: 1px solid #ddd4c8;
}

/* ---- Content area ---- */
QStackedWidget#content-area { background-color: #f6f1eb; }

QWidget#page-scaffold,
QWidget#page-header,
QWidget#page-body,
QWidget#page-toolbar-slot,
QWidget#page-banner-slot,
QWidget#page-stats-slot,
QWidget#page-header-action-slot {
    background: transparent;
}

QLabel#page-eyebrow {
    background: transparent;
    color: #8f8377;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.4px;
    text-transform: uppercase;
}

QWidget#page-toolbar {
    background-color: transparent;
}

QWidget#page-scaffold[quietHeader="true"] QLabel#page-date {
    color: #7d7469;
}

QWidget#stat-strip {
    background-color: #f7f1e8;
    border: 1px solid #ddd1c3;
    border-radius: 16px;
}

QWidget#stat-strip[density="compact"] {
    border-radius: 14px;
}

QWidget#stat-strip-card {
    background-color: rgba(255,255,255,0.52);
    border: 1px solid rgba(0,0,0,0.045);
    border-radius: 12px;
}

QLabel#stat-strip-value {
    background: transparent;
    color: #191610;
    font-size: 24px;
    font-weight: 700;
}

QWidget#stat-strip[density="compact"] QLabel#stat-strip-value {
    font-size: 20px;
}

QLabel#stat-strip-label {
    background: transparent;
    color: #786f63;
    font-size: 12px;
    font-weight: 600;
}

QWidget#stat-strip[density="compact"] QLabel#stat-strip-label {
    font-size: 11px;
}

QLabel#stat-strip-detail {
    background: transparent;
    color: #9a9084;
    font-size: 11px;
}

QWidget#section-header {
    background: transparent;
}

QLabel#section-header-title {
    background: transparent;
    color: #17130f;
    font-size: 18px;
    font-weight: 650;
}

QLabel#section-header-subtitle {
    background: transparent;
    color: #7b7267;
    font-size: 13px;
}

QWidget#segmented-tabs {
    background: transparent;
}

QPushButton#segmented-tab-btn {
    background-color: #f3ece4;
    color: #6e665d;
    border: 1px solid #dacdbf;
    border-radius: 18px;
    padding: 0 16px;
    min-height: 36px;
    font-size: 13px;
    font-weight: 500;
}

QPushButton#segmented-tab-btn:hover {
    background-color: #ede3d7;
    color: #211c17;
    border-color: #ccbba8;
}

QPushButton#segmented-tab-btn[active="true"] {
    background-color: rgba(255, 107, 53, 0.10);
    color: #d65a27;
    border: 1px solid rgba(255, 107, 53, 0.24);
    font-weight: 600;
}

QToolButton#overflow-action-btn {
    background-color: #f2ebe2;
    color: #6a6157;
    border: 1px solid #d7cabd;
    border-radius: 10px;
    padding: 0 12px;
    min-height: 36px;
    font-size: 12px;
    font-weight: 600;
}

QToolButton#overflow-action-btn:hover {
    background-color: #ede2d6;
    color: #221c17;
    border-color: #cbbbab;
}

QMenu {
    background-color: #fffaf5;
    color: #221c17;
    border: 1px solid #dccfc1;
    padding: 6px;
}

QMenu::item {
    padding: 8px 18px;
    border-radius: 8px;
}

QMenu::item:selected {
    background-color: rgba(255, 107, 53, 0.10);
    color: #d65a27;
}

QWidget#status-banner {
    background-color: #f7f0e8;
    border: 1px solid #e3d6c8;
    border-radius: 12px;
}

QWidget#status-banner[variant="system"] {
    background-color: #f7f0e8;
    border-color: #e3d6c8;
}

QWidget#status-banner[variant="info"] {
    background-color: #f7f0e8;
    border-color: #e3d6c8;
}

QWidget#status-banner[variant="success"] {
    background-color: #f7f0e8;
    border-color: #e3d6c8;
}

QWidget#status-banner[variant="warning"] {
    background-color: rgba(255, 107, 53, 0.06);
    border-color: rgba(255, 107, 53, 0.18);
}

QWidget#status-banner[variant="error"] {
    background-color: rgba(239, 68, 68, 0.08);
    border-color: rgba(239, 68, 68, 0.22);
}

QLabel#status-banner-text {
    background: transparent;
    color: #685f55;
    font-size: 13px;
}

QWidget#empty-state-card {
    background-color: #f8f1e9;
    border: 1px dashed #ddcfbf;
    border-radius: 16px;
}

QLabel#empty-state-icon {
    background: transparent;
    color: #988c80;
    font-size: 24px;
}

QLabel#empty-state-title {
    background: transparent;
    color: #17130f;
    font-size: 18px;
    font-weight: 650;
}

QLabel#empty-state-body {
    background: transparent;
    color: #7b7267;
    font-size: 13px;
}

/* ---- Cards ---- */
QWidget#card {
    background-color: #fff9f3;
    border-radius: 14px;
    border: 1px solid #e4d9cb;
}

QWidget#stat-card {
    background-color: #fff9f3;
    border-radius: 14px;
    border: 1px solid #e4d9cb;
}

QWidget#plan-card {
    background-color: #fff9f3;
    border-radius: 14px;
    border: 1px solid #e4d9cb;
}

QWidget#claude-card {
    background-color: #fffaf7;
    border-radius: 14px;
    border: 1px solid rgba(255, 107, 53, 0.3);
}

QWidget#accent-card {
    background-color: rgba(255, 107, 53, 0.05);
    border-radius: 14px;
    border: 1px solid rgba(255, 107, 53, 0.22);
}

QWidget#meal-slot {
    background-color: #fbf6ef;
    border-radius: 10px;
    border: 1px solid #e1d5c8;
}
QWidget#meal-slot:hover {
    border-color: rgba(255, 107, 53, 0.32);
    background-color: rgba(255, 107, 53, 0.04);
}

/* ---- Content divider (inline widget dividers) ---- */
QWidget#content-divider {
    background-color: #ddd2c5;
}

/* ---- Typography ---- */
QLabel#page-title {
    background-color: transparent;
    color: #171512;
    font-size: 30px;
    font-weight: 700;
    letter-spacing: -0.4px;
}

QLabel#page-date {
    background-color: transparent;
    color: #746d63;
    font-size: 13px;
}

QLabel#section-label {
    background-color: transparent;
    color: #847b70;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.4px;
}

QLabel#stat-value {
    background-color: transparent;
    color: #171512;
    font-size: 30px;
    font-weight: 700;
}

QLabel#stat-label {
    background-color: transparent;
    color: #756e64;
    font-size: 12px;
    font-weight: 500;
}

QLabel#card-title {
    background-color: transparent;
    color: #27211b;
    font-size: 16px;
    font-weight: 600;
}

QLabel#card-body {
    background-color: transparent;
    color: #6d655b;
    font-size: 13px;
}

QLabel#tip-text {
    background-color: transparent;
    color: #7a5c40;
    font-size: 13px;
}

QLabel#meal-slot-label {
    background-color: transparent;
    color: #7b7267;
    font-size: 12px;
}

QLabel#placeholder-text {
    background-color: transparent;
    color: #786f64;
    font-size: 17px;
    font-weight: 500;
}

QLabel#placeholder-sub {
    background-color: transparent;
    color: #8a8176;
    font-size: 13px;
}

QLabel#claude-feature-lbl {
    background-color: transparent;
    color: #6d655b;
    font-size: 13px;
}

QLabel#claude-notice {
    background-color: transparent;
    color: #756e64;
    font-size: 12px;
}

/* ---- Primary button ---- */
QPushButton#primary-btn {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #ff7d4d, stop:1 #e85d25);
    color: #ffffff;
    border: 1px solid #c04818;
    border-radius: 10px;
    padding: 0 22px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.4px;
    min-height: 34px;
}
QPushButton#primary-btn:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #ff9060, stop:1 #f07035);
    border-color: rgba(180, 70, 25, 0.4);
}
QPushButton#primary-btn:pressed {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #d85520, stop:1 #c04818);
    border-color: rgba(160, 60, 20, 0.45);
}
QPushButton#primary-btn:disabled {
    background: #e8e8e8;
    color: #aaaaaa;
    border-color: #cccccc;
}

QPushButton#ghost-btn {
    background-color: #f2ebe2;
    color: #746b61;
    border: 1px solid #d8cbbd;
    border-radius: 8px;
    padding: 0px 12px;
    font-size: 12px;
    font-weight: 600;
    min-height: 34px;
}
QPushButton#ghost-btn:hover {
    background-color: #ede2d6;
    color: #221d18;
    border-color: #d0c2b4;
}

QPushButton#quick-action-btn {
    background-color: #fffaf5;
    color: #6b6258;
    border: 1px solid #e1d5c8;
    border-radius: 14px;
    padding: 16px 20px;
    font-size: 14px;
    font-weight: 500;
    text-align: left;
}
QPushButton#quick-action-btn:hover {
    background-color: #f3e9dd;
    color: #221d18;
    border-color: #d2c2b1;
}

/* ---- Inputs ---- */
QLineEdit {
    background-color: #ffffff;
    color: #221d18;
    border: 1px solid #d8ccbf;
    border-radius: 10px;
    padding: 10px 14px;
    font-size: 14px;
    min-height: 20px;
    selection-background-color: rgba(255, 107, 53, 0.2);
    selection-color: #1a1a1a;
}
QLineEdit:focus { border-color: rgba(255, 107, 53, 0.42); background-color: #ffffff; color: #221d18; }
QLineEdit::placeholder { color: #9c9185; }
QLineEdit:disabled { color: #9c9185; background-color: #f5efe7; border-color: #e5d9cc; }

/* ---- Combo boxes ---- */
QComboBox {
    background-color: #ffffff;
    color: #221d18;
    border: 1px solid #d8ccbf;
    border-radius: 10px;
    padding: 10px 12px;
    font-size: 14px;
    min-height: 20px;
}
QComboBox:focus { border-color: rgba(255, 107, 53, 0.42); }
QComboBox::drop-down { border: none; width: 22px; }
QComboBox QAbstractItemView {
    background-color: #ffffff;
    color: #221d18;
    border: 1px solid #d8ccbf;
    selection-background-color: rgba(255, 107, 53, 0.15);
    selection-color: #1a1a1a;
    font-size: 14px;
    padding: 4px;
}
QComboBox QAbstractItemView::item { min-height: 28px; padding: 4px 10px; }

/* ---- Checkbox ---- */
QCheckBox {
    background-color: transparent;
    color: #27211b;
    font-size: 13px;
    font-weight: 600;
    spacing: 10px;
}
QCheckBox::indicator {
    width: 19px;
    height: 19px;
    border-radius: 5px;
    border: 1.5px solid #c9bbab;
    background-color: #ffffff;
}
QCheckBox::indicator:hover  { border-color: #ff6b35; }
QCheckBox::indicator:checked { background-color: #ff6b35; border-color: #ff6b35; }

/* ---- Shopping items ---- */
QWidget#shopping-item {
    background-color: #fffdf9;
    border-radius: 10px;
    border: 1px solid #e5d9cc;
    min-height: 56px;
}

QPushButton#delete-btn {
    background-color: transparent;
    border: none;
    border-radius: 6px;
    padding: 2px;
}
QPushButton#delete-btn:hover { background-color: rgba(255, 107, 53, 0.1); }

/* ---- Progress bars ---- */
QProgressBar {
    background-color: #e7dccf;
    border-radius: 4px;
    border: none;
}
QProgressBar::chunk { border-radius: 4px; background-color: #ff6b35; }

/* ---- Scrollbars ---- */
QScrollBar:vertical { background: transparent; width: 5px; margin: 0; }
QScrollBar::handle:vertical { background: #cdbfae; border-radius: 2px; min-height: 24px; }
QScrollBar::handle:vertical:hover { background: #b6a897; }
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0; }

QScrollBar:horizontal { background: transparent; height: 5px; }
QScrollBar::handle:horizontal { background: #cdbfae; border-radius: 2px; min-width: 24px; }
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal { width: 0; }

/* ---- Status bar ---- */
QStatusBar {
    background-color: #f2ebe3;
    color: #756e64;
    border-top: 1px solid #ddd4c8;
    font-size: 11px;
    padding: 2px 10px;
}
QStatusBar::item { border: none; }

/* ---- Scroll area ---- */
QScrollArea { border: none; background-color: transparent; }
QScrollArea > QWidget > QWidget { background-color: transparent; }

/* ---- Dialogs ---- */
QDialog {
    background-color: #faf5ef;
    color: #221d18;
}
QDialogButtonBox QPushButton {
    background-color: #f3ece4;
    color: #686157;
    border: 1px solid #d9cdc0;
    border-radius: 8px;
    padding: 8px 18px;
    font-size: 13px;
    font-weight: 600;
}
QDialogButtonBox QPushButton:hover {
    background-color: #ebdfd3;
    color: #221d18;
    border-color: #cdbdac;
}
QDialogButtonBox QPushButton[text="OK"],
QDialogButtonBox QPushButton[text="Save"] {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #ff7d4d, stop:1 #e85d25);
    color: #ffffff;
    border: 1px solid #c04818;
}
QDialogButtonBox QPushButton[text="OK"]:hover,
QDialogButtonBox QPushButton[text="Save"]:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #ff9060, stop:1 #f07035);
    border-color: rgba(180, 70, 25, 0.4);
}

/* ---- Message boxes ---- */
QMessageBox {
    background-color: #faf5ef;
    color: #221d18;
}
QMessageBox QPushButton {
    background-color: #f3ece4;
    color: #686157;
    border: 1px solid #d9cdc0;
    border-radius: 8px;
    padding: 8px 18px;
    min-width: 70px;
    font-size: 13px;
    font-weight: 600;
}
QMessageBox QPushButton:hover {
    background-color: #ebdfd3;
    color: #221d18;
    border-color: #cdbdac;
}

/* ---- Tooltips ---- */
QToolTip {
    background-color: #1f2937;
    color: #f8fafc;
    border: 1px solid #334155;
    border-radius: 5px;
    padding: 4px 8px;
    font-size: 12px;
}
QLineEdit#page-search-input {
    background-color: #ffffff;
    border: 1px solid #d8ccbf;
    border-radius: 14px;
    min-height: 42px;
    padding: 0 16px;
    font-size: 14px;
}

QLineEdit#page-search-input:focus {
    border-color: rgba(255, 107, 53, 0.42);
}

QWidget#recipe-panel {
    background-color: #fff9f3;
    border: 1px solid #e4d9cb;
    border-radius: 16px;
}

QWidget#recipe-stream-shell {
    background: transparent;
}

QWidget#recipe-library-row,
QWidget#recipe-result-row {
    background-color: #fff9f3;
    border: 1px solid #e1d5c8;
    border-radius: 14px;
}

QWidget#recipe-library-row:hover,
QWidget#recipe-result-row:hover {
    background-color: #f7efe6;
    border-color: #d2c2b1;
}

QLabel#recipe-overline {
    background: transparent;
    color: #8b8074;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.2px;
    text-transform: uppercase;
}

QLabel#recipe-row-title {
    background: transparent;
    color: #191510;
    font-size: 15px;
    font-weight: 650;
}

QLabel#recipe-row-meta {
    background: transparent;
    color: #756d63;
    font-size: 12px;
}

QLabel#recipe-row-body {
    background: transparent;
    color: #867d72;
    font-size: 12px;
}

QLabel#recipe-chip {
    background: rgba(0,0,0,0.03);
    color: #7c7368;
    border: 1px solid rgba(0,0,0,0.05);
    border-radius: 12px;
    padding: 3px 9px;
    font-size: 11px;
    font-weight: 600;
}

QPushButton#chip-btn,
QToolButton#chip-btn {
    background-color: #f2ebe2;
    color: #7a7065;
    border: 1px solid #ddd1c4;
    border-radius: 14px;
    padding: 0 12px;
    min-height: 28px;
    font-size: 11px;
    font-weight: 600;
}

QPushButton#chip-btn:hover,
QToolButton#chip-btn:hover {
    background-color: #ede2d6;
    color: #221d18;
    border-color: rgba(255, 107, 53, 0.18);
}

QPushButton#chip-btn[active="true"],
QToolButton#chip-btn[active="true"] {
    background-color: rgba(255, 107, 53, 0.08);
    color: #d45b2a;
    border: 1px solid rgba(255, 107, 53, 0.2);
}
