/* ============================================================
   DishBoard — Light mode theme
   Comfortable off-white palette, same orange accent #ff6b35
   ============================================================ */

* {
    font-family: "Segoe UI", "SF Pro Text", -apple-system,
                 ".AppleSystemUIFont", "Helvetica Neue", Arial, sans-serif;
}

QMainWindow, QWidget {
    background-color: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #f8fafc, stop:0.48 #f2f5f8, stop:1 #eef3f7
    );
    color: #182130;
}

/* ---- Sidebar ---- */
QWidget#sidebar {
    background-color: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #f1f5f9, stop:1 #e8eef4
    );
    border-right: 1px solid #d8e0e8;
}

QLabel#app-logo-label {
    background-color: transparent;
    color: #111111;
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
}

QWidget#sidebar-divider {
    background-color: #d3dbe5;
    max-height: 1px;
    min-height: 1px;
}

QWidget#sidebar-accent {
    background-color: #ff6b35;
    max-height: 2px;
    min-height: 2px;
    border-radius: 1px;
}

QLabel#sidebar-section-label {
    background-color: transparent;
    color: #888888;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    padding: 0 18px;
}

QLabel#sidebar-date-lbl {
    background-color: transparent;
    color: #64748b;
    font-size: 12px;
    padding: 0 18px;
}

QLabel#sidebar-version-lbl {
    background-color: transparent;
    color: #7b8ca2;
    font-size: 11px;
    padding: 0 18px;
}

/* ---- Nav buttons ---- */
QPushButton#nav-btn {
    background-color: transparent;
    color: #4d5f77;
    border: none;
    border-radius: 10px;
    padding: 0 15px;
    text-align: left;
    font-size: 14px;
    font-weight: 500;
    margin: 1px 8px;
}

QPushButton#nav-btn:hover {
    background-color: qlineargradient(
        x1:0, y1:0, x2:1, y2:0,
        stop:0 #e8eef5, stop:1 #dfe8f1
    );
    color: #111827;
}

QPushButton#nav-btn:checked {
    background-color: rgba(255, 107, 53, 0.1);
    color: #e55a22;
    font-weight: 600;
    border-left: 2px solid #ff6b35;
    padding-left: 12px;
}

QPushButton#toggle-btn {
    background-color: transparent;
    border: none;
    border-radius: 7px;
    padding: 2px;
}
QPushButton#toggle-btn:hover { background-color: #e4ebf2; }

/* ---- Back bar ---- */
QWidget#back-bar {
    background-color: #edf1f5;
    border-bottom: 1px solid #d6dee8;
}

/* ---- Content area ---- */
QStackedWidget#content-area { background-color: #f4f6f8; }

/* ---- Cards ---- */
QWidget#card {
    background-color: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #ffffff, stop:1 #f8fbff
    );
    border-radius: 14px;
    border: 1px solid #dfe6ee;
}

QWidget#stat-card {
    background-color: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #ffffff, stop:1 #f7faff
    );
    border-radius: 14px;
    border: 1px solid #dfe6ee;
}

QWidget#plan-card {
    background-color: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #ffffff, stop:1 #f8fbff
    );
    border-radius: 14px;
    border: 1px solid #dfe6ee;
}

QWidget#claude-card {
    background-color: #fffaf7;
    border-radius: 14px;
    border: 1px solid rgba(255, 107, 53, 0.3);
}

QWidget#accent-card {
    background-color: rgba(255, 107, 53, 0.05);
    border-radius: 14px;
    border: 1px solid rgba(255, 107, 53, 0.22);
}

QWidget#meal-slot {
    background-color: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #fafdff, stop:1 #f4f8fc
    );
    border-radius: 10px;
    border: 1px solid #d9e2ed;
}
QWidget#meal-slot:hover {
    border-color: rgba(255, 107, 53, 0.55);
    background-color: rgba(255, 107, 53, 0.05);
}

/* ---- Content divider (inline widget dividers) ---- */
QWidget#content-divider {
    background-color: #d2dbe7;
}

/* ---- Typography ---- */
QLabel#page-title {
    background-color: transparent;
    color: #0f1724;
    font-size: 30px;
    font-weight: 700;
    letter-spacing: -0.4px;
}

QLabel#page-date {
    background-color: transparent;
    color: #5e7087;
    font-size: 13px;
}

QLabel#section-label {
    background-color: transparent;
    color: #6e819a;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.4px;
}

QLabel#stat-value {
    background-color: transparent;
    color: #0f1724;
    font-size: 30px;
    font-weight: 700;
}

QLabel#stat-label {
    background-color: transparent;
    color: #6d7f95;
    font-size: 12px;
    font-weight: 500;
}

QLabel#card-title {
    background-color: transparent;
    color: #162235;
    font-size: 16px;
    font-weight: 600;
}

QLabel#card-body {
    background-color: transparent;
    color: #5f6f84;
    font-size: 13px;
}

QLabel#tip-text {
    background-color: transparent;
    color: #7a5c40;
    font-size: 13px;
}

QLabel#meal-slot-label {
    background-color: transparent;
    color: #6f8096;
    font-size: 12px;
}

QLabel#placeholder-text {
    background-color: transparent;
    color: #6b7c92;
    font-size: 17px;
    font-weight: 500;
}

QLabel#placeholder-sub {
    background-color: transparent;
    color: #7b8ca2;
    font-size: 13px;
}

QLabel#claude-feature-lbl {
    background-color: transparent;
    color: #5f6f84;
    font-size: 13px;
}

QLabel#claude-notice {
    background-color: transparent;
    color: #6d7f95;
    font-size: 12px;
}

/* ---- Primary button ---- */
QPushButton#primary-btn {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #ff7d4d, stop:1 #e85d25);
    color: #ffffff;
    border: 1px solid #c04818;
    border-radius: 10px;
    padding: 0 22px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.4px;
    min-height: 34px;
}
QPushButton#primary-btn:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #ff9060, stop:1 #f07035);
    border-color: rgba(180, 70, 25, 0.4);
}
QPushButton#primary-btn:pressed {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #d85520, stop:1 #c04818);
    border-color: rgba(160, 60, 20, 0.45);
}
QPushButton#primary-btn:disabled {
    background: #e8e8e8;
    color: #aaaaaa;
    border-color: #cccccc;
}

QPushButton#ghost-btn {
    background-color: #eef2f6;
    color: #50627a;
    border: 1px solid #d0d9e4;
    border-radius: 8px;
    padding: 0px 12px;
    font-size: 12px;
    font-weight: 600;
}
QPushButton#ghost-btn:hover {
    background-color: #e4ebf2;
    color: #111827;
    border-color: #b8c4d4;
}

QPushButton#quick-action-btn {
    background-color: #fbfcfd;
    color: #4f6079;
    border: 1px solid #dbe3ed;
    border-radius: 14px;
    padding: 16px 20px;
    font-size: 14px;
    font-weight: 500;
    text-align: left;
}
QPushButton#quick-action-btn:hover {
    background-color: #f2f6fa;
    color: #111827;
    border-color: #c3cfdd;
}

/* ---- Inputs ---- */
QLineEdit {
    background-color: #ffffff;
    color: #152133;
    border: 1px solid #cbd5e1;
    border-radius: 10px;
    padding: 10px 14px;
    font-size: 14px;
    min-height: 20px;
    selection-background-color: rgba(255, 107, 53, 0.2);
    selection-color: #1a1a1a;
}
QLineEdit:focus { border-color: rgba(255, 107, 53, 0.62); background-color: #ffffff; color: #152133; }
QLineEdit::placeholder { color: #93a2b5; }
QLineEdit:disabled { color: #93a2b5; background-color: #f3f5f8; border-color: #dbe2eb; }

/* ---- Combo boxes ---- */
QComboBox {
    background-color: #ffffff;
    color: #152133;
    border: 1px solid #cbd5e1;
    border-radius: 10px;
    padding: 10px 12px;
    font-size: 14px;
    min-height: 20px;
}
QComboBox:focus { border-color: rgba(255, 107, 53, 0.62); }
QComboBox::drop-down { border: none; width: 22px; }
QComboBox QAbstractItemView {
    background-color: #ffffff;
    color: #152133;
    border: 1px solid #cbd5e1;
    selection-background-color: rgba(255, 107, 53, 0.15);
    selection-color: #1a1a1a;
    font-size: 14px;
    padding: 4px;
}
QComboBox QAbstractItemView::item { min-height: 28px; padding: 4px 10px; }

/* ---- Checkbox ---- */
QCheckBox {
    background-color: transparent;
    color: #1a2a40;
    font-size: 13px;
    font-weight: 600;
    spacing: 10px;
}
QCheckBox::indicator {
    width: 19px;
    height: 19px;
    border-radius: 5px;
    border: 1.5px solid #b7c3d3;
    background-color: #ffffff;
}
QCheckBox::indicator:hover  { border-color: #ff6b35; }
QCheckBox::indicator:checked { background-color: #ff6b35; border-color: #ff6b35; }

/* ---- Shopping items ---- */
QWidget#shopping-item {
    background-color: #fbfcfd;
    border-radius: 10px;
    border: 1px solid #dbe3ed;
    min-height: 56px;
}

QPushButton#delete-btn {
    background-color: transparent;
    border: none;
    border-radius: 6px;
    padding: 2px;
}
QPushButton#delete-btn:hover { background-color: rgba(255, 107, 53, 0.1); }

/* ---- Progress bars ---- */
QProgressBar {
    background-color: #dbe2ec;
    border-radius: 4px;
    border: none;
}
QProgressBar::chunk { border-radius: 4px; background-color: #ff6b35; }

/* ---- Scrollbars ---- */
QScrollBar:vertical { background: transparent; width: 5px; margin: 0; }
QScrollBar::handle:vertical { background: #bcc7d6; border-radius: 2px; min-height: 24px; }
QScrollBar::handle:vertical:hover { background: #a0aec0; }
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0; }

QScrollBar:horizontal { background: transparent; height: 5px; }
QScrollBar::handle:horizontal { background: #bcc7d6; border-radius: 2px; min-width: 24px; }
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal { width: 0; }

/* ---- Status bar ---- */
QStatusBar {
    background-color: #edf1f5;
    color: #6e819a;
    border-top: 1px solid #d6dee8;
    font-size: 11px;
    padding: 2px 10px;
}
QStatusBar::item { border: none; }

/* ---- Scroll area ---- */
QScrollArea { border: none; background-color: transparent; }
QScrollArea > QWidget > QWidget { background-color: transparent; }

/* ---- Dialogs ---- */
QDialog {
    background-color: #f7f9fc;
    color: #152133;
}
QDialogButtonBox QPushButton {
    background-color: #eef2f6;
    color: #4f6079;
    border: 1px solid #d0d9e4;
    border-radius: 8px;
    padding: 8px 18px;
    font-size: 13px;
    font-weight: 600;
}
QDialogButtonBox QPushButton:hover {
    background-color: #e4ebf2;
    color: #111827;
    border-color: #b8c4d4;
}
QDialogButtonBox QPushButton[text="OK"],
QDialogButtonBox QPushButton[text="Save"] {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #ff7d4d, stop:1 #e85d25);
    color: #ffffff;
    border: 1px solid #c04818;
}
QDialogButtonBox QPushButton[text="OK"]:hover,
QDialogButtonBox QPushButton[text="Save"]:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #ff9060, stop:1 #f07035);
    border-color: rgba(180, 70, 25, 0.4);
}

/* ---- Message boxes ---- */
QMessageBox {
    background-color: #f7f9fc;
    color: #152133;
}
QMessageBox QPushButton {
    background-color: #eef2f6;
    color: #4f6079;
    border: 1px solid #d0d9e4;
    border-radius: 8px;
    padding: 8px 18px;
    min-width: 70px;
    font-size: 13px;
    font-weight: 600;
}
QMessageBox QPushButton:hover {
    background-color: #e4ebf2;
    color: #111827;
    border-color: #b8c4d4;
}

/* ---- Tooltips ---- */
QToolTip {
    background-color: #1f2937;
    color: #f8fafc;
    border: 1px solid #334155;
    border-radius: 5px;
    padding: 4px 8px;
    font-size: 12px;
}
