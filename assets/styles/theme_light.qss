/* ============================================================
   DishBoard — Light mode theme
   Comfortable off-white palette, same orange accent #ff6b35
   ============================================================ */

* {
    font-family: "SF Pro Display", "SF Pro Text", -apple-system,
                 ".AppleSystemUIFont", "Helvetica Neue", Arial, sans-serif;
}

QMainWindow, QWidget {
    background-color: #f5f5f5;
    color: #1a1a1a;
}

/* ---- Sidebar ---- */
QWidget#sidebar {
    background-color: #eeeeee;
    border-right: 1px solid #cccccc;
}

QLabel#app-logo-label {
    background-color: transparent;
    color: #111111;
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
}

QWidget#sidebar-divider {
    background-color: #cccccc;
    max-height: 1px;
    min-height: 1px;
}

QWidget#sidebar-accent {
    background-color: #ff6b35;
    max-height: 2px;
    min-height: 2px;
    border-radius: 1px;
}

QLabel#sidebar-section-label {
    background-color: transparent;
    color: #888888;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    padding: 0 18px;
}

QLabel#sidebar-date-lbl {
    background-color: transparent;
    color: #666666;
    font-size: 12px;
    padding: 0 18px;
}

QLabel#sidebar-version-lbl {
    background-color: transparent;
    color: #999999;
    font-size: 11px;
    padding: 0 18px;
}

/* ---- Nav buttons ---- */
QPushButton#nav-btn {
    background-color: transparent;
    color: #444444;
    border: none;
    border-radius: 8px;
    padding: 0 14px;
    text-align: left;
    font-size: 14px;
    font-weight: 500;
    margin: 1px 8px;
}

QPushButton#nav-btn:hover {
    background-color: #e2e2e2;
    color: #111111;
}

QPushButton#nav-btn:checked {
    background-color: rgba(255, 107, 53, 0.1);
    color: #e55a22;
    font-weight: 600;
    border-left: 2px solid #ff6b35;
    padding-left: 12px;
}

QPushButton#toggle-btn {
    background-color: transparent;
    border: none;
    border-radius: 7px;
    padding: 2px;
}
QPushButton#toggle-btn:hover { background-color: #e2e2e2; }

/* ---- Back bar ---- */
QWidget#back-bar {
    background-color: #ebebeb;
    border-bottom: 1px solid #cccccc;
}

/* ---- Content area ---- */
QStackedWidget#content-area { background-color: #f5f5f5; }

/* ---- Cards ---- */
QWidget#card {
    background-color: #ffffff;
    border-radius: 12px;
    border: 1px solid #cccccc;
}

QWidget#stat-card {
    background-color: #ffffff;
    border-radius: 12px;
    border: 1px solid #cccccc;
}

QWidget#plan-card {
    background-color: #ffffff;
    border-radius: 12px;
    border: 1px solid #cccccc;
}

QWidget#claude-card {
    background-color: #fffcf9;
    border-radius: 12px;
    border: 1px solid rgba(255, 107, 53, 0.3);
}

QWidget#accent-card {
    background-color: rgba(255, 107, 53, 0.05);
    border-radius: 12px;
    border: 1px solid rgba(255, 107, 53, 0.22);
}

QWidget#meal-slot {
    background-color: #f5f5f5;
    border-radius: 10px;
    border: 1px solid #d0d0d0;
}
QWidget#meal-slot:hover {
    border-color: rgba(255, 107, 53, 0.55);
    background-color: rgba(255, 107, 53, 0.05);
}

/* ---- Content divider (inline widget dividers) ---- */
QWidget#content-divider {
    background-color: #bbbbbb;
}

/* ---- Typography ---- */
QLabel#page-title {
    background-color: transparent;
    color: #111111;
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.5px;
}

QLabel#page-date {
    background-color: transparent;
    color: #555555;
    font-size: 14px;
}

QLabel#section-label {
    background-color: transparent;
    color: #555555;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.4px;
}

QLabel#stat-value {
    background-color: transparent;
    color: #111111;
    font-size: 32px;
    font-weight: 700;
}

QLabel#stat-label {
    background-color: transparent;
    color: #555555;
    font-size: 13px;
    font-weight: 500;
}

QLabel#card-title {
    background-color: transparent;
    color: #222222;
    font-size: 15px;
    font-weight: 600;
}

QLabel#card-body {
    background-color: transparent;
    color: #444444;
    font-size: 14px;
}

QLabel#tip-text {
    background-color: transparent;
    color: #7a5c40;
    font-size: 14px;
}

QLabel#meal-slot-label {
    background-color: transparent;
    color: #666666;
    font-size: 13px;
}

QLabel#placeholder-text {
    background-color: transparent;
    color: #666666;
    font-size: 16px;
    font-weight: 500;
}

QLabel#placeholder-sub {
    background-color: transparent;
    color: #888888;
    font-size: 14px;
}

QLabel#claude-feature-lbl {
    background-color: transparent;
    color: #555555;
    font-size: 14px;
}

QLabel#claude-notice {
    background-color: transparent;
    color: #777777;
    font-size: 12px;
}

/* ---- Primary button ---- */
QPushButton#primary-btn {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #ff7d4d, stop:1 #e85d25);
    color: #ffffff;
    border: 1px solid #c04818;
    border-radius: 10px;
    padding: 0 22px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.4px;
    min-height: 34px;
}
QPushButton#primary-btn:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #ff9060, stop:1 #f07035);
    border-color: rgba(180, 70, 25, 0.4);
}
QPushButton#primary-btn:pressed {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #d85520, stop:1 #c04818);
    border-color: rgba(160, 60, 20, 0.45);
}
QPushButton#primary-btn:disabled {
    background: #e8e8e8;
    color: #aaaaaa;
    border-color: #cccccc;
}

QPushButton#ghost-btn {
    background-color: #ebebeb;
    color: #333333;
    border: 1px solid #bbbbbb;
    border-radius: 6px;
    padding: 0px 10px;
    font-size: 11px;
    font-weight: 500;
}
QPushButton#ghost-btn:hover {
    background-color: #e0e0e0;
    color: #111111;
    border-color: #999999;
}

QPushButton#quick-action-btn {
    background-color: #f8f8f8;
    color: #333333;
    border: 1px solid #cccccc;
    border-radius: 12px;
    padding: 20px 22px;
    font-size: 14px;
    font-weight: 500;
    text-align: left;
}
QPushButton#quick-action-btn:hover {
    background-color: #efefef;
    color: #111111;
    border-color: #aaaaaa;
}

/* ---- Inputs ---- */
QLineEdit {
    background-color: #ffffff;
    color: #1a1a1a;
    border: 1px solid #bbbbbb;
    border-radius: 9px;
    padding: 10px 16px;
    font-size: 14px;
    min-height: 20px;
    selection-background-color: rgba(255, 107, 53, 0.2);
    selection-color: #1a1a1a;
}
QLineEdit:focus { border-color: rgba(255, 107, 53, 0.6); background-color: #ffffff; color: #1a1a1a; }
QLineEdit::placeholder { color: #aaaaaa; }
QLineEdit:disabled { color: #aaaaaa; background-color: #f0f0f0; border-color: #dddddd; }

/* ---- Combo boxes ---- */
QComboBox {
    background-color: #ffffff;
    color: #1a1a1a;
    border: 1px solid #bbbbbb;
    border-radius: 9px;
    padding: 10px 14px;
    font-size: 14px;
    min-height: 20px;
}
QComboBox:focus { border-color: rgba(255, 107, 53, 0.6); }
QComboBox::drop-down { border: none; width: 22px; }
QComboBox QAbstractItemView {
    background-color: #ffffff;
    color: #1a1a1a;
    border: 1px solid #bbbbbb;
    selection-background-color: rgba(255, 107, 53, 0.15);
    selection-color: #1a1a1a;
    font-size: 14px;
    padding: 4px;
}
QComboBox QAbstractItemView::item { min-height: 28px; padding: 4px 10px; }

/* ---- Checkbox ---- */
QCheckBox {
    background-color: transparent;
    color: #222222;
    font-size: 14px;
    spacing: 10px;
}
QCheckBox::indicator {
    width: 19px;
    height: 19px;
    border-radius: 5px;
    border: 1.5px solid #aaaaaa;
    background-color: #ffffff;
}
QCheckBox::indicator:hover  { border-color: #ff6b35; }
QCheckBox::indicator:checked { background-color: #ff6b35; border-color: #ff6b35; }

/* ---- Shopping items ---- */
QWidget#shopping-item {
    background-color: #f8f8f8;
    border-radius: 10px;
    border: 1px solid #cccccc;
    min-height: 56px;
}

QPushButton#delete-btn {
    background-color: transparent;
    border: none;
    border-radius: 6px;
    padding: 2px;
}
QPushButton#delete-btn:hover { background-color: rgba(255, 107, 53, 0.1); }

/* ---- Progress bars ---- */
QProgressBar {
    background-color: #dddddd;
    border-radius: 4px;
    border: none;
}
QProgressBar::chunk { border-radius: 4px; background-color: #ff6b35; }

/* ---- Scrollbars ---- */
QScrollBar:vertical { background: transparent; width: 5px; margin: 0; }
QScrollBar::handle:vertical { background: #bbbbbb; border-radius: 2px; min-height: 24px; }
QScrollBar::handle:vertical:hover { background: #999999; }
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0; }

QScrollBar:horizontal { background: transparent; height: 5px; }
QScrollBar::handle:horizontal { background: #bbbbbb; border-radius: 2px; min-width: 24px; }
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal { width: 0; }

/* ---- Status bar ---- */
QStatusBar {
    background-color: #eeeeee;
    color: #888888;
    border-top: 1px solid #cccccc;
    font-size: 11px;
    padding: 2px 10px;
}
QStatusBar::item { border: none; }

/* ---- Scroll area ---- */
QScrollArea { border: none; background-color: transparent; }
QScrollArea > QWidget > QWidget { background-color: transparent; }

/* ---- Dialogs ---- */
QDialog {
    background-color: #f5f5f5;
    color: #1a1a1a;
}
QDialogButtonBox QPushButton {
    background-color: #ebebeb;
    color: #333333;
    border: 1px solid #bbbbbb;
    border-radius: 7px;
    padding: 8px 18px;
    font-size: 13px;
}
QDialogButtonBox QPushButton:hover {
    background-color: #e0e0e0;
    color: #111111;
}
QDialogButtonBox QPushButton[text="OK"],
QDialogButtonBox QPushButton[text="Save"] {
    background-color: #ff6b35;
    color: #ffffff;
    border: none;
}
QDialogButtonBox QPushButton[text="OK"]:hover,
QDialogButtonBox QPushButton[text="Save"]:hover {
    background-color: #ff7d4d;
}

/* ---- Message boxes ---- */
QMessageBox {
    background-color: #f5f5f5;
    color: #1a1a1a;
}
QMessageBox QPushButton {
    background-color: #ebebeb;
    color: #333333;
    border: 1px solid #bbbbbb;
    border-radius: 7px;
    padding: 8px 18px;
    min-width: 70px;
    font-size: 13px;
}
QMessageBox QPushButton:hover {
    background-color: #e0e0e0;
    color: #111111;
}

/* ---- Tooltips ---- */
QToolTip {
    background-color: #333333;
    color: #f0f0f0;
    border: 1px solid #444444;
    border-radius: 5px;
    padding: 4px 8px;
    font-size: 12px;
}
